{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/repo-checks-on-stop.py\"",
            "timeout": 600,
            "statusMessage": "Running repo checks"
          }
        ]
      }
    ]
  }
}
